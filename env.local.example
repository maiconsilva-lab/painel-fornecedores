# ═════════════════════════════════════════════════════════════════════
# PREMIX — CENTRAL DE CADASTROS PROTHEUS
# Copie para .env.local e também cadastre no Vercel.
# Nunca versione valores reais de service role, sessão ou chave privada.
# ═════════════════════════════════════════════════════════════════════

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
# A chave anon só é necessária para protótipos legados; o painel ativo usa APIs server-side.
NEXT_PUBLIC_SUPABASE_ANON_KEY=CHAVE_ANON_OPCIONAL
SUPABASE_SERVICE_ROLE_KEY=CHAVE_SERVICE_ROLE_PRIVADA

# Sessão assinada HttpOnly — gere um segredo aleatório com pelo menos 32 bytes.
SESSION_SECRET=SEGREDO_LONGO_E_ALEATORIO

# EmailJS — agora usados somente pelo servidor em /api/email.
EMAILJS_SERVICE=SEU_SERVICE_ID
EMAILJS_PUBLIC=SUA_PUBLIC_KEY
EMAILJS_TEMPLATE_APROVADO=SEU_TEMPLATE_APROVADO
EMAILJS_TEMPLATE_DEVOLVIDO=SEU_TEMPLATE_DEVOLVIDO
EMAILJS_TEMPLATE_DESBLOQ=SEU_TEMPLATE_DESBLOQUEIO

# Formulário público utilizado nas devolutivas para correção.
NEXT_PUBLIC_CORRECTION_FORM_URL=https://formulario-fornecedor-nine.vercel.app

# Sincronização Google Sheets → Supabase (pendências fiscais)
GOOGLE_SERVICE_ACCOUNT_EMAIL=conta-servico@projeto.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nSUA_CHAVE\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=ID_DA_PLANILHA

# Proteção do Vercel Cron /api/sync-sheets.
CRON_SECRET=SEGREDO_ALEATORIO_DO_CRON
