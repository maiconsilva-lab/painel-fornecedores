# Credenciais do EmailJS
# Coloque este arquivo na RAIZ do projeto Next.js (no mesmo nível do package.json).
# IMPORTANTE: este arquivo NÃO entra no Git (já está no .gitignore por padrão do Next.js).
# Variáveis NEXT_PUBLIC_* são expostas ao browser (intencionalmente, porque a chave é "public").

NEXT_PUBLIC_EMAILJS_SERVICE=service_w7xzoya
NEXT_PUBLIC_EMAILJS_PUBLIC=A5igXA6RKwkf84zyR
NEXT_PUBLIC_EMAILJS_TEMPLATE_APROVADO=template_9r33gy7
NEXT_PUBLIC_EMAILJS_TEMPLATE_DEVOLVIDO=template_devolvido
NEXT_PUBLIC_EMAILJS_TEMPLATE_DESBLOQ=template_desbloqueado

# Protege /api/sync-sheets contra chamadas externas não autorizadas.
# Defina esta variável no Vercel (Settings -> Environment Variables) com um
# valor aleatório qualquer. O Vercel Cron envia esse valor automaticamente
# no header Authorization quando a variável existe no projeto.
CRON_SECRET=troque_por_um_valor_aleatorio

# ─────────────────────────────────────────────────────────────────────
# IMPORTANTE para o deploy no Vercel:
# Adicione estas mesmas variáveis em: Vercel → Settings → Environment Variables
# Senão o deploy de produção vai usar os fallbacks (valores antigos hardcoded).
# ─────────────────────────────────────────────────────────────────────
